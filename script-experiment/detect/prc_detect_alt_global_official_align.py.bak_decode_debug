def _resolve_existing_dir(p: str, name: str) -> str:
    rp = str(Path(p).expanduser().resolve())
    if not os.path.isdir(rp):
        raise FileNotFoundError(f"{name} not found: {rp}")
    return rp


def _ensure_parent_dir(path_like: str) -> str:
    out = str(Path(path_like).expanduser().resolve())
    os.makedirs(str(Path(out).parent), exist_ok=True)
    return out


def _resolve_existing_file(p: str, name: str) -> str:
    rp = str(Path(p).expanduser().resolve())
    if not os.path.isfile(rp):
        raise FileNotFoundError(f"{name} not found: {rp}")
    return rp


def _resolve_torch_dtype(dtype_str: str) -> torch.dtype:
    s = (dtype_str or "fp32").lower()
    if s in ("fp16", "float16"):
        return torch.float16
    if s in ("bf16", "bfloat16"):
        return torch.bfloat16
    return torch.float32


def _infer_project_root(run_dir: Optional[str], zt_path: Optional[str]) -> str:
    seeds: List[Path] = [Path(__file__).resolve().parents[2]]
    if run_dir:
        seeds.append(Path(run_dir).expanduser().resolve())
    if zt_path:
        seeds.append(Path(zt_path).expanduser().resolve().parent)
    for seed in seeds:
        for cand in [seed, *seed.parents]:
            if (cand / "script-experiment").is_dir():
                return str(cand)
    return str(seeds[0])


def _is_prc_repo_candidate(base_dir: str) -> bool:
    base = Path(base_dir)
    cands = [
        base / "src" / "prc.py",
        base / "prc.py",
    ]
    gauss_cands = [
        base / "src" / "pseudogaussians.py",
        base / "pseudogaussians.py",
    ]
    return any(p.is_file() for p in cands) and any(p.is_file() for p in gauss_cands)


def _resolve_prc_repo(prc_repo_arg: Optional[str], project_root: str) -> Tuple[Optional[str], List[str]]:
    tried: List[str] = []
    if prc_repo_arg:
        p = str(Path(prc_repo_arg).expanduser().resolve())
        tried.append(p)
        if os.path.isdir(p) and _is_prc_repo_candidate(p):
            return p, tried
        if not os.path.isdir(p):
            print(f"[WARN] --prc_repo not found, will auto-search: {p}")
        else:
            print(f"[WARN] --prc_repo exists but does not look like a PRC repo, will auto-search: {p}")

    project = Path(project_root).expanduser().resolve()
    cands = [
        str(project / "third_party" / "PRC-Watermark-main"),
        str(project / "PRC-Watermark-main"),
        str(project.parent / "PRC-Watermark-main"),
        str(project.parent / "third_party" / "PRC-Watermark-main"),
        str(Path(__file__).resolve().parent),
    ]
    for c in cands:
        cc = str(Path(c).expanduser().resolve())
        tried.append(cc)
        if os.path.isdir(cc) and _is_prc_repo_candidate(cc):
            return cc, tried
    return None, tried


def _add_prc_repo_to_syspath(prc_repo: Optional[str]) -> None:
    script_dir = str(Path(__file__).resolve().parent)
    if script_dir not in sys.path:
        sys.path.insert(0, script_dir)
    if prc_repo and os.path.isdir(prc_repo):
        if prc_repo not in sys.path:
            sys.path.insert(0, prc_repo)
        src = os.path.join(prc_repo, "src")
        if os.path.isdir(src) and src not in sys.path:
            sys.path.insert(0, src)


def _import_official_modules():
    """Import PRC official modules needed by decode path.

    Returns:
      prc_lib, prc_gaussians, optim_utils_or_none
    """
    global _PRC_IMPORT_CACHE
    if _PRC_IMPORT_CACHE is not None:
        return _PRC_IMPORT_CACHE

    prc_errs: List[str] = []
    gauss_errs: List[str] = []
    optim_errs: List[str] = []

    try:
        try:
            import prc as prc_lib  # type: ignore
            prc_from = "prc"
        except Exception as e1:
            prc_errs.append(repr(e1))
            from src import prc as prc_lib  # type: ignore
            prc_from = "src.prc"
    except Exception as e2:
        prc_errs.append(repr(e2))
        raise RuntimeError(
            "Failed to import PRC decode module. Tried: prc, src.prc. "
            f"Errors: {' | '.join(prc_errs)}"
        )

    try:
        try:
            import pseudogaussians as prc_gaussians  # type: ignore
            gauss_from = "pseudogaussians"
        except Exception as e1:
            gauss_errs.append(repr(e1))
            from src import pseudogaussians as prc_gaussians  # type: ignore
            gauss_from = "src.pseudogaussians"
    except Exception as e2:
        gauss_errs.append(repr(e2))
        raise RuntimeError(
            "Failed to import PRC posterior module. Tried: pseudogaussians, src.pseudogaussians. "
            f"Errors: {' | '.join(gauss_errs)}"
        )

    optim_utils = None
    optim_from = "unavailable"
    try:
        try:
            import optim_utils as optim_utils  # type: ignore
            optim_from = "optim_utils"
        except Exception as e1:
            optim_errs.append(repr(e1))
            from src import optim_utils as optim_utils  # type: ignore
            optim_from = "src.optim_utils"
    except Exception as e2:
        optim_errs.append(repr(e2))
        print(
            "[WARN] failed to import optim_utils; detection path does not require it. "
            f"Errors: {' | '.join(optim_errs)}",
            flush=True,
        )

    print(
        "[INFO] imported PRC modules:",
        f"prc={prc_from}, gaussians={gauss_from}, optim_utils={optim_from}",
        flush=True,
    )
    _PRC_IMPORT_CACHE = (prc_lib, prc_gaussians, optim_utils)
    return _PRC_IMPORT_CACHE


def _load_prc_keys(meta_dir: str, key_path: Optional[str] = None) -> Tuple[Any, Dict[str, Any]]:
    tried: List[str] = []
    key_cands = []
    if key_path:
        key_cands.append(str(Path(key_path).expanduser().resolve()))
    key_cands += [
        os.path.join(meta_dir, "prc_keys.pkl"),
        os.path.join(meta_dir, "keys.pkl"),
        os.path.join(meta_dir, "prc_decoding_key.pkl"),
        os.path.join(meta_dir, "decoding_key.pkl"),
        os.path.join(meta_dir, "prc_key.pkl"),
    ]

    obj = None
    chosen = None
    for p in key_cands:
        tried.append(p)
        if os.path.isfile(p):
            with open(p, "rb") as f:
                obj = pickle.load(f)
            chosen = p
            break

    if obj is None:
        raise FileNotFoundError("Missing PRC key file. Tried:\n  " + "\n  ".join(tried))

    decoding_key = None
    if isinstance(obj, dict):
        for k in ("decoding_key", "decoding", "dk"):
            if k in obj:
                decoding_key = obj[k]
                break
        if decoding_key is None and "encoding_key" in obj and "decoding_key" in obj:
            decoding_key = obj["decoding_key"]
    elif isinstance(obj, (tuple, list)) and len(obj) >= 2:
        decoding_key = obj[1]
    else:
        decoding_key = obj

    if decoding_key is None:
        raise RuntimeError(f"Loaded {chosen} but could not extract decoding_key.")

    meta: Dict[str, Any] = {"key_file": chosen}
    for mp in [
        os.path.join(meta_dir, "prc_global_meta.json"),
        os.path.join(meta_dir, "prc_meta.json"),
        os.path.join(meta_dir, "meta.json"),
    ]:
        if os.path.isfile(mp):
            try:
                with open(mp, "r", encoding="utf-8") as f:
                    meta.update(json.load(f))
            except Exception:
                pass

    return decoding_key, meta


def _infer_key_n_and_target_size(decoding_key) -> Tuple[Optional[int], Optional[int], Optional[Tuple[int, int]]]:
    try:
        gen = decoding_key[0]
        shp = tuple(getattr(gen, "shape", ()))
        if len(shp) >= 2:
            n = int(max(int(shp[0]), int(shp[1])))
        else:
            n = None
    except Exception:
        n = None

    hlat = None
    target = None
    if n is not None:
        if n == 4 * 64 * 64:
            hlat = 64
            target = (512, 512)
        elif n == 4 * 96 * 96:
            hlat = 96
            target = (768, 768)
        else:
            h = int(round(math.sqrt(n / 4)))
            if 4 * h * h == n:
                hlat = h
                target = (h * 8, h * 8)
    return n, hlat, target


def _resolve_meta_dir(
    meta_dir: Optional[str],
    meta_root: Optional[str],
    wm_meta_dir: Optional[str],
    run_dir: Optional[str],
    zt_dir: Optional[str],
    project_root: str,
    copy_wm_meta_to_run_dir: bool = False,
) -> Tuple[str, List[str]]:
    tried: List[str] = []

    explicit = wm_meta_dir or meta_dir or meta_root
    explicit_resolved = None
    if explicit:
        explicit_resolved = str(Path(explicit).expanduser().resolve())
        tried.append(explicit_resolved)
        if not os.path.isdir(explicit_resolved):
            raise FileNotFoundError(f"wm_meta/meta dir not found: {explicit_resolved}")

    if copy_wm_meta_to_run_dir:
        if not run_dir:
            raise ValueError("--copy_wm_meta_to_run_dir requires --run_dir in image mode.")
        if not explicit_resolved:
            raise ValueError("--copy_wm_meta_to_run_dir requires explicit --wm_meta_dir/--meta_dir/--meta_root.")
        target = str((Path(run_dir).expanduser().resolve() / "wm_meta"))
        os.makedirs(str(Path(run_dir).expanduser().resolve()), exist_ok=True)
        shutil.copytree(explicit_resolved, target, dirs_exist_ok=True)
        return target, tried

    if run_dir:
        run_wm_meta = str((Path(run_dir).expanduser().resolve() / "wm_meta"))
        tried.append(run_wm_meta)
        if os.path.isdir(run_wm_meta):
            return run_wm_meta, tried
        if explicit_resolved:
            return explicit_resolved, tried
        raise FileNotFoundError(
            "Could not resolve wm_meta dir for image mode. Expected run_dir/wm_meta or explicit "
            "--wm_meta_dir/--meta_dir. Tried:\n  " + "\n  ".join(tried)
        )

    if explicit_resolved:
        return explicit_resolved, tried

    cands: List[str] = []
    if zt_dir:
        cands.extend(
            [
                os.path.join(zt_dir, "wm_meta"),
                os.path.join(Path(zt_dir).parent, "wm_meta"),
            ]
        )

    for c in cands:
        cc = str(Path(c).expanduser().resolve())
        tried.append(cc)
        if os.path.isdir(cc):
            return cc, tried

    raise FileNotFoundError(
        "Could not resolve wm_meta dir. Pass --wm_meta_dir/--meta_dir explicitly if needed. Tried:\n  "
        + "\n  ".join(tried)
    )


