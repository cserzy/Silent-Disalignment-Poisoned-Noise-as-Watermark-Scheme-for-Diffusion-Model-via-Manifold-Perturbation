    ap.add_argument("--zT_start", type=int, default=0, help="Start index in zT bank for direct mode.")
    ap.add_argument("--zT_count", type=int, default=0, help="Optional item count in zT direct mode.")

    ap.add_argument("--fpr", type=float, default=1e-2, help="False positive rate passed to PRC Detect.")
    ap.add_argument("--variances", type=float, default=1.5, help="Variance parameter for recover_posteriors.")
    ap.add_argument("--var", type=float, default=None, help="Alias of --variances.")
    ap.add_argument("--max_bp_iter", type=int, default=1000, help="PRC BP decoder max iterations for Decode(...).")

    ap.add_argument("--out_csv", default=None, help="Output CSV path.")
    ap.add_argument("--save_zt", action="store_true", help="Save approximate Alt-inverted zT tensors in image mode.")
    ap.add_argument("--save_zt_dir", default=None, help="Optional directory for saved zT tensors.")
    ap.add_argument("--disable_safety_checker", dest="disable_safety_checker", action="store_true",
                    help="Disable safety checker and feature extractor (default).")
    ap.add_argument("--enable_safety_checker", dest="disable_safety_checker", action="store_false",
                    help="Enable safety checker and feature extractor.")
    ap.add_argument("--master_key", type=str, default="prc_key_yx_0504",
                    help="Used for bit-accuracy GT derivation if prc_message_bits.txt is missing.")
    ap.add_argument("--message_length", type=int, default=8, help="Expected message bit length for bit_acc.")
    ap.add_argument("--debug", action="store_true", help="Print extra debug information.")
    ap.set_defaults(disable_safety_checker=True)

    args = ap.parse_args()

    if (args.zT_pt is None) == (args.run_dir is None):
        raise ValueError("Provide exactly one of --zT_pt or --run_dir.")
    direct_zt = args.zT_pt is not None

    limit_eff = _resolve_limit(args.max_images, args.limit, args.zT_count)
    var_eff = float(args.var) if args.var is not None else float(args.variances)
    project_root = _infer_project_root(args.run_dir, args.zT_pt)
    prc_repo, prc_repo_tried = _resolve_prc_repo(args.prc_repo, project_root)
    _add_prc_repo_to_syspath(prc_repo)
    prc_lib, prc_gaussians, optim_utils = _import_official_modules()

    run_dir = str(Path(args.run_dir).expanduser().resolve()) if args.run_dir else None
    zt_path = str(Path(args.zT_pt).expanduser().resolve()) if args.zT_pt else None
    zt_dir = str(Path(zt_path).parent) if zt_path else None

    meta_dir, meta_tried = _resolve_meta_dir(
        meta_dir=args.meta_dir,
        meta_root=args.meta_root,
        wm_meta_dir=args.wm_meta_dir,
        run_dir=run_dir,
        zt_dir=zt_dir,
        project_root=project_root,
        copy_wm_meta_to_run_dir=bool(args.copy_wm_meta_to_run_dir),
    )
    meta_dir = _resolve_existing_dir(meta_dir, "wm_meta/meta dir")

    decoding_key, meta = _load_prc_keys(meta_dir, key_path=args.key_path)
    resolved_key_path = str(meta.get("key_file", ""))
    key_n, key_hlat, key_target = _infer_key_n_and_target_size(decoding_key)
    wm_meta_paths = _wm_meta_file_paths(meta_dir)

    msg_file = os.path.join(meta_dir, "prc_message_bits.txt")
    expected_bits = None
    msg_bits_file_len = None
    if os.path.isfile(msg_file):
        s = Path(msg_file).read_text(encoding="utf-8").strip().replace(" ", "")
        import numpy as np

        msg_bits_file_len = len(s)
        expected_bits = np.array([int(ch) for ch in s], dtype=np.int64)[: int(args.message_length)]
    elif args.master_key:
        expected_bits = expected_bits_from_master(args.master_key, int(args.message_length))

    if direct_zt:
        out_base = zt_dir or str(Path.cwd())
        out_csv = args.out_csv or os.path.join(out_base, "detect_results_prcGLOBAL_alt_from_zT.csv")
    else:
        out_base = run_dir or str(Path.cwd())
        out_csv = args.out_csv or os.path.join(out_base, "detect_results_prcGLOBAL_alt.csv")
    out_csv = _ensure_parent_dir(out_csv)

    print("[CFG] mode=", "direct_zT" if direct_zt else "image_alt")
    print("[CFG] prc_repo=", prc_repo)
    print("[CFG] prc_repo_search_tried=", len(prc_repo_tried), "locations")
    print("[CFG] wm_meta_dir=", meta_dir)
    print("[CFG] wm_meta_search_tried=", len(meta_tried), "locations")
    print("[CFG] decoding_key=", wm_meta_paths["decoding_key"], "exists=", os.path.isfile(wm_meta_paths["decoding_key"]))
    print("[CFG] encoding_key=", wm_meta_paths["encoding_key"], "exists=", os.path.isfile(wm_meta_paths["encoding_key"]))
    print("[CFG] prc_keys=", wm_meta_paths["prc_keys"], "exists=", os.path.isfile(wm_meta_paths["prc_keys"]))
    print("[CFG] prc_message_bits=", wm_meta_paths["prc_message_bits"], "exists=", os.path.isfile(wm_meta_paths["prc_message_bits"]))
    print("[CFG] prc_meta=", wm_meta_paths["prc_meta"], "exists=", os.path.isfile(wm_meta_paths["prc_meta"]))
    print("[CFG] key_file=", resolved_key_path)
    print("[CFG] out_csv=", out_csv)
    print("[CFG] fpr=", float(args.fpr))
    print("[CFG] variances=", var_eff)
    print("[CFG] message_length=", int(args.message_length))
    print("[CFG] max_bp_iter=", int(args.max_bp_iter))
    print("[CFG] cache_dir=", args.cache_dir, "(ignored in Alt image mode)")
    print("[CFG] solver_order/inv_order/decoder_inv are kept for CLI compatibility and ignored in Alt image mode")
    if key_n is not None:
        print("[KEY] expected_n=", key_n, "target_size=", key_target)
    if expected_bits is not None:
        print("[KEY] expected_message_bits_length=", int(expected_bits.size), "message_bits_file_length=", msg_bits_file_len)
    if args.debug:
        print("[DBG] optim_utils_imported=", bool(optim_utils is not None))

    with open(out_csv, "w", newline="", encoding="utf-8") as f:
        w = csv.writer(f)
        w.writerow([
            "image_path",
            "detected",
            "score",
            "decode_ok",
            "decoded_bits",
            "bit_acc",
            "prompt_used",
            "inv_steps",
            "guidance",
            "variances",
            "fpr",
            "max_bp_iter",
            "key_file",
        ])

    detected_cnt = 0
    bit_acc_sum = 0.0
    bit_acc_cnt = 0

    if direct_zt:
        zT = _load_zT_tensor_from_pt(zt_path)
        if key_hlat is not None and tuple(zT.shape[2:]) != (key_hlat, key_hlat):
            raise ValueError(
                f"zT latent size mismatch: expected spatial {(key_hlat, key_hlat)}, got {tuple(zT.shape[2:])}"
            )

        N = int(zT.shape[0])
        start = int(args.zT_start)
        if start < 0 or start >= N:
            raise ValueError(f"--zT_start out of range: {start} (N={N})")
        total = N - start
        if limit_eff > 0:
            total = min(total, int(limit_eff))
        end = start + total
        zT = zT[start:end].contiguous()

        print("[CFG] zT_pt=", zt_path)
        print("[CFG] zT_range=", f"[{start}:{end})", "count=", total, "bs=", int(args.inv_bs))

        n = int(zT.shape[0])
        bs = max(1, int(args.inv_bs))
        for i in range(0, n, bs):
            batch = zT[i:i + bs]
            batch_names = [f"zT:{start + i + j:04d}" for j in range(batch.shape[0])]
            flags, scores, decoded_strs, bit_accs, decode_oks = _detect_one_batch(
                decoding_key=decoding_key,
                prc_gaussians=prc_gaussians,
                prc_lib=prc_lib,
                reversed_latents=batch,
                var=var_eff,
                fpr=float(args.fpr),
                max_bp_iter=int(args.max_bp_iter),
                key_n_expected=key_n,
                expected_bits=expected_bits,
                names=batch_names,
                print_each=False,
                show_k=64,
            )
            with open(out_csv, "a", newline="", encoding="utf-8") as f:
                w = csv.writer(f)
                for j, name in enumerate(batch_names):
                    det = int(bool(flags[j]))
                    sc = float(scores[j])
                    dec = decoded_strs[j]
                    acc = float(bit_accs[j])
                    decode_ok = int(bool(decode_oks[j]))
                    detected_cnt += det
                    if expected_bits is not None and not math.isnan(acc):
                        bit_acc_sum += acc
                        bit_acc_cnt += 1
                    prefix = dec[:64] if dec is not None else "None"
                    if expected_bits is not None:
                        print(
                            f"[{i+j+1:5d}/{n}] {name} detected={det} score={sc:.6g} "
                            f"decode={'OK' if decode_ok else 'FAIL'} bit_acc={acc:.3f} dec[:64]={prefix}"
                        )
                    else:
                        print(
                            f"[{i+j+1:5d}/{n}] {name} detected={det} score={sc:.6g} "
                            f"decode={'OK' if decode_ok else 'FAIL'} dec[:64]={prefix}"
                        )
                    w.writerow([
                        name,
                        det,
                        sc,
                        decode_ok,
                        dec if dec is not None else "",
                        acc if expected_bits is not None else float("nan"),
                        "",
                        int(args.inv_steps),
                        float(args.guidance),
                        var_eff,
                        float(args.fpr),
                        int(args.max_bp_iter),
                        resolved_key_path,
                    ])

        detect_rate = detected_cnt / float(n) if n > 0 else 0.0
        avg_bit_acc = (bit_acc_sum / float(bit_acc_cnt)) if bit_acc_cnt > 0 else float("nan")
        if expected_bits is not None:
            print(f"[SUMMARY] detect_rate={detect_rate:.4f}  avg_bit_acc={avg_bit_acc:.4f}  n={n}")
        else:
            print(f"[SUMMARY] detect_rate={detect_rate:.4f}  n={n}")
        print(f"[DONE] wrote {out_csv} | {n} zT samples")
        return

    if not run_dir:
        raise ValueError("--run_dir is required in image mode.")
    if not args.model_id:
        raise ValueError("--model_id is required in image mode.")

    img_paths = _collect_images_from_run_dir(run_dir)
    if limit_eff > 0:
        img_paths = img_paths[:limit_eff]
    if not img_paths:
        raise FileNotFoundError(f"No images found under run_dir: {run_dir}")

    manifest_path = None
    manifest_tried: List[str] = []
    fixed_prompt = ""
    if args.prompt is not None:
        fixed_prompt = str(args.prompt)
    elif args.prompt_mode == "first_manifest":
        manifest_path, manifest_tried = _resolve_manifest_csv(run_dir)
        if manifest_path:
            try:
                with open(manifest_path, "r", encoding="utf-8") as f:
                    reader = csv.DictReader(f)
                    first = next(reader, None)
                    if first and first.get("prompt") is not None:
                        fixed_prompt = str(first.get("prompt") or "")
            except Exception:
                fixed_prompt = ""

    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    torch_dtype = _resolve_torch_dtype(args.dtype)
    target_size_px = int(key_target[0]) if key_target is not None else 512

    print("[CFG] run_dir=", run_dir)
    print("[CFG] images=", len(img_paths), "inv_bs=", int(args.inv_bs))
    print("[CFG] model_id=", str(Path(args.model_id).expanduser().resolve()) if os.path.exists(args.model_id) else args.model_id)
    print("[CFG] prompt_mode=", args.prompt_mode, "prompt_used=", repr(fixed_prompt))
    print("[CFG] manifest_found=", bool(manifest_path), "manifest_csv=", manifest_path if manifest_path else "")
    if args.prompt_mode == "first_manifest" and (not manifest_path) and args.debug:
        print("[DBG] manifest_search_tried=", manifest_tried)
    print("[CFG] inv_steps=", int(args.inv_steps), "guidance=", float(args.guidance))
    print("[CFG] dtype=", str(torch_dtype).replace("torch.", ""), "device=", device)
    print("[CFG] disable_safety_checker=", bool(args.disable_safety_checker))
    print("[CFG] Alt inversion is approximate, not official strict inversion")

    pipe = build_alt_pipe(
        model_id=args.model_id,
        device=device,
        dtype=torch_dtype,
        disable_safety_checker=bool(args.disable_safety_checker),
    )

    save_zt_dir = None
    if args.save_zt:
        default_zt_dir = Path(args.save_zt_dir).expanduser().resolve() if args.save_zt_dir else Path(out_base) / "latents_prc_alt"
        save_zt_dir = Path(default_zt_dir)
        save_zt_dir.mkdir(parents=True, exist_ok=True)
        print("[CFG] save_zt_dir=", str(save_zt_dir))

    n = len(img_paths)
    bs = max(1, int(args.inv_bs))
    for i in range(0, n, bs):
        batch_paths = img_paths[i:i + bs]
        batch_imgs = [Image.open(p).convert("RGB") for p in batch_paths]
        batch_names = [os.path.basename(p) for p in batch_paths]
        reversed_latents = invert_batch_images_to_zT_alt(
            pipe,
            batch_imgs,
            inv_steps=int(args.inv_steps),
            device=device,
            dtype=torch_dtype,
            prompt=fixed_prompt,
            guidance_scale=float(args.guidance),
            target_size=target_size_px,
        )
        if args.debug:
            print("[DBG] inverted_latents.shape=", tuple(reversed_latents.shape))

        flags, scores, decoded_strs, bit_accs, decode_oks = _detect_one_batch(
            decoding_key=decoding_key,
            prc_gaussians=prc_gaussians,
            prc_lib=prc_lib,
            reversed_latents=reversed_latents,
            var=var_eff,
            fpr=float(args.fpr),
            max_bp_iter=int(args.max_bp_iter),
            key_n_expected=key_n,
            expected_bits=expected_bits,
            names=batch_names,
            print_each=False,
            show_k=64,
        )

        with open(out_csv, "a", newline="", encoding="utf-8") as f:
            w = csv.writer(f)
            for j, p in enumerate(batch_paths):
                idx = i + j
                det = int(bool(flags[j]))
                sc = float(scores[j])
                dec = decoded_strs[j]
                acc = float(bit_accs[j])
                decode_ok = int(bool(decode_oks[j]))
                detected_cnt += det
                if expected_bits is not None and not math.isnan(acc):
                    bit_acc_sum += acc
                    bit_acc_cnt += 1
                if save_zt_dir is not None:
                    stem = Path(p).stem
                    zt_save_path = save_zt_dir / f"{stem}_zT.pt"
                    torch.save(reversed_latents[j:j + 1].cpu(), zt_save_path)
                prefix = dec[:64] if dec is not None else "None"
                if expected_bits is not None:
                    print(
                        f"[{idx+1:5d}/{n}] {Path(p).name} detected={det} score={sc:.6g} "
                        f"decode={'OK' if decode_ok else 'FAIL'} bit_acc={acc:.3f} dec[:64]={prefix}"
                    )
                else:
                    print(
                        f"[{idx+1:5d}/{n}] {Path(p).name} detected={det} score={sc:.6g} "
                        f"decode={'OK' if decode_ok else 'FAIL'} dec[:64]={prefix}"
                    )
                w.writerow([
                    p,
                    det,
                    sc,
                    decode_ok,
                    dec if dec is not None else "",
                    acc if expected_bits is not None else float("nan"),
                    fixed_prompt,
                    int(args.inv_steps),
                    float(args.guidance),
                    var_eff,
                    float(args.fpr),
                    int(args.max_bp_iter),
                    resolved_key_path,
                ])

    detect_rate = detected_cnt / float(n) if n > 0 else 0.0
    avg_bit_acc = (bit_acc_sum / float(bit_acc_cnt)) if bit_acc_cnt > 0 else float("nan")
    if expected_bits is not None:
        print(f"[SUMMARY] detect_rate={detect_rate:.4f}  avg_bit_acc={avg_bit_acc:.4f}  n={n}")
    else:
        print(f"[SUMMARY] detect_rate={detect_rate:.4f}  n={n}")
    print(f"[DONE] wrote {out_csv} | {n} images")


if __name__ == "__main__":
    main()
